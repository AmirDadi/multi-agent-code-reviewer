# LLM provider keys (at least one required)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Langfuse observability (optional — tracing is skipped if not set)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Model overrides (optional — defaults shown)
REVIEWER_FAST_MODEL=gemini/gemini-2.0-flash-lite
REVIEWER_STRONG_MODEL=gemini/gemini-2.0-flash
REVIEWER_MID_MODEL=gemini/gemini-2.0-flash
REVIEWER_SECURITY_MODEL=claude-haiku-4-5
REVIEWER_STRONGEST_MODEL=gemini/gemini-2.0-flash
