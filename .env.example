# LLM provider keys (at least one required)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Langfuse observability (optional — tracing is skipped if not set)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Model overrides (optional — defaults shown)
REVIEWER_FAST_MODEL=gemini/gemini-2.0-flash-lite
REVIEWER_STRONG_MODEL=anthropic/claude-3-5-sonnet-20241022
REVIEWER_MID_MODEL=anthropic/claude-3-5-haiku-20241022
REVIEWER_STRONGEST_MODEL=anthropic/claude-opus-4-5
